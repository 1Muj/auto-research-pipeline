# Optional: run self-hosted runner inside Docker on a GPU host with NVIDIA runtime.
# Build: docker build -f deploy/Dockerfile.gpu-runner -t auto-research-runner .
# Run:   docker run --gpus all -e GITHUB_TOKEN -e GITHUB_REPO ... (see deploy/README snippets in scripts)

FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY . /workspace
RUN pip3 install --no-cache-dir -e ".[dev,anthropic]"

ENV PYTHONPATH=/workspace/src
CMD ["bash", "-lc", "auto-research run --cwd /workspace -e experiments/example.yaml"]
